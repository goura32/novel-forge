{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "goal", "outcome", "conflict", "pov_character_id", "character_ids", "key_events", "location_id", "hook", "turning_point", "emotional_arc", "ending_hook", "canon_updates"],
  "properties": {
    "title": {"type": "string"},
    "goal": {"type": "string"},
    "outcome": {"type": "string"},
    "conflict": {"type": "string"},
    "pov_character_id": {"type": "string", "description": "canon_context.characters[].id の完全一致。表示名は禁止。"},
    "character_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "description": "canon_context.characters[].id の完全一致。"}},
    "location_id": {"type": "string", "description": "canon_context.locations[].id の完全一致。場所の情景は sensory_focus に書く。"},
    "key_events": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "hook": {"type": "string"},
    "turning_point": {"type": "string"},
    "emotional_arc": {"type": "string"},
    "ending_hook": {"type": "string"},
    "sensory_focus": {"type": "array", "items": {"type": "string"}},
    "subtext": {"type": "string"},
    "foreshadowing": {"type": "array", "items": {"type": "string"}},
    "canon_updates": {
      "type": "array",
      "description": "既存 Canon への単純な更新意図。create や曖昧な参照は禁止。Python が strict CanonPatch にコンパイルする。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation", "target_id", "value"],
        "properties": {
          "operation": {"type": "string", "enum": ["set_character_state", "set_location_state", "set_artifact_condition", "transfer_artifact"]},
          "target_id": {"type": "string", "description": "canon_context 内の対象 Canon ID。"},
          "value": {"type": "string", "description": "新しい状態・条件。"},
          "holder_id": {"type": "string", "description": "transfer_artifact の新しい保持者（canon_context.characters[].id）。"}
        }
      }
    }
  },
  "description": "厳格なID参照を使う1シーンの詳細設計。"
}
