{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanVolumes",
  "description": "シリーズ企画の各巻設計。世界観とキャラクターを踏まえて各巻のタイトルと前提を設計する。",
  "type": "object",
  "properties": {
    "planned_volumes": {
      "description": "巻構成一覧。4〜8個推奨。最低4巻（起承転結の各段階を最低1巻ずつ）。",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "premise",
          "theme",
          "emotional_arc",
          "key_events",
          "cliffhanger"
        ],
        "properties": {
          "title": {
            "description": "巻タイトル。3〜64文字推奨。",
            "type": "string",
            "minLength": 1
          },
          "premise": {
            "description": "巻のあらすじ。300〜1000文字推奨。",
            "type": "string",
            "minLength": 1
          },
          "theme": {
            "description": "巻のテーマ。100〜600文字推奨。",
            "type": "string",
            "minLength": 1
          },
          "emotional_arc": {
            "description": "巻全体の感情の弧。100〜500文字推奨。",
            "type": "string",
            "minLength": 1
          },
          "key_events": {
            "description": "巻内の主要イベント。3〜10個推奨、各最大200文字。",
            "type": "array",
            "items": {
              "type": "string",
              "description": "key events。key eventsの文脈で後続の設計・執筆に使える具体的な日本語で書く。",
              "minLength": 1
            },
            "minItems": 1
          },
          "cliffhanger": {
            "description": "次巻へのフック。全巻で非空。最終巻では続刊の未解決 cliffhanger ではなく、物語の余韻・未来へのフック・読後に残る問いを書く。100〜1000文字推奨。",
            "type": "string",
            "minLength": 1
          }
        },
        "description": "planned volumesを構造化して表すオブジェクト。関連する下位フィールドを具体的に埋める。",
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "planned_volumes"
  ],
  "additionalProperties": false
}
