{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bible",
  "type": "object",
  "required": [
    "characters",
    "glossary",
    "foreshadowing",
    "world_rules",
    "relationships",
    "subplots"
  ],
  "properties": {
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "キャラクター名"
          },
          "role": {
            "type": "string",
            "description": "役割"
          },
          "arc": {
            "type": "string",
            "description": "成長軌跡"
          },
          "appearance": {
            "type": "string",
            "description": "外見"
          },
          "personality": {
            "type": "string",
            "description": "性格"
          },
          "motivation": {
            "type": "string",
            "description": "動機・目的"
          },
          "state": {
            "type": "string",
            "description": "状態"
          }
        },
        "description": "キャラクタープロフィール一覧"
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "term",
          "definition"
        ],
        "properties": {
          "term": {
            "type": "string",
            "description": "用語"
          },
          "definition": {
            "type": "string",
            "description": "定義"
          }
        },
        "description": "用語集"
      }
    },
    "foreshadowing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "description"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "伏線の説明"
          },
          "resolved": {
            "type": "boolean"
          }
        },
        "description": "伏線一覧"
      }
    },
    "world_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "世界のルール"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "character_a": {
            "type": "string"
          },
          "character_b": {
            "type": "string"
          },
          "relationship_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "change_direction": {
            "type": "string",
            "enum": [
              "改善",
              "悪化",
              "変化",
              "変化なし"
            ]
          },
          "trigger_event": {
            "type": "string"
          },
          "scene_number": {
            "type": "integer"
          }
        },
        "description": "キャラクター関係一覧"
      }
    },
    "subplots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "未着手",
              "進行中",
              "完了"
            ]
          },
          "progress_note": {
            "type": "string"
          },
          "related_characters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_foreshadowing_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "サブプロット一覧"
      }
    }
  }
}