{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bible",
  "type": "object",
  "required": [
    "characters",
    "glossary",
    "foreshadowing",
    "world_rules"
  ],
  "properties": {
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 64,
            "description": "キャラクター名"
          },
          "appearance": {
            "type": "string",
            "maxLength": 200,
            "description": "外見"
          },
          "personality": {
            "type": "string",
            "maxLength": 200,
            "description": "性格"
          },
          "state": {
            "type": "string",
            "maxLength": 200,
            "description": "状態"
          }
        }
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "term",
          "definition"
        ],
        "properties": {
          "term": {
            "type": "string",
            "maxLength": 64,
            "description": "用語"
          },
          "definition": {
            "type": "string",
            "maxLength": 200,
            "description": "定義"
          }
        }
      }
    },
    "foreshadowing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "description"
        ],
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 200,
            "description": "伏線の説明"
          },
          "resolved": {
            "type": "boolean"
          }
        }
      }
    },
    "world_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200,
        "description": "世界のルール"
      }
    }
  }
}
