{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesign",
  "description": "巻の章構成設計。巻タイトル、前提、各章のタイトルと役割を定義する。",
  "type": "object",
  "required": [
    "chapters"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "巻タイトル"
    },
    "premise": {
      "type": "string",
      "maxLength": 200,
      "description": "巻の前提"
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 128,
            "description": "章タイトル"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ],
            "description": "章の役割"
          }
        }
      },
      "minItems": 1
    }
  }
}
