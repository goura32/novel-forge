{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesign",
  "type": "object",
  "required": [
    "chapters"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "巻タイトル"
    },
    "premise": {
      "type": "string",
      "maxLength": 500,
      "description": "巻の前提"
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 128
          },
          "purpose": {
            "type": "string",
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ],
            "description": "章の役割。日本語で指定: 導入/展開/転換/クライマックス/収束"
          },
          "scenes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "goal",
                "outcome"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "maxLength": 128
                },
                "pov": {
                  "type": "string",
                  "maxLength": 64
                },
                "goal": {
                  "type": "string",
                  "maxLength": 400
                },
                "conflict": {
                  "type": "string",
                  "maxLength": 300
                },
                "outcome": {
                  "type": "string",
                  "maxLength": 400
                },
                "characters": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "maxLength": 64
                  }
                },
                "key_events": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "maxLength": 200
                  },
                  "description": "主要イベント"
                },
                "setting": {
                  "type": "string",
                  "maxLength": 200,
                  "description": "舞台設定"
                }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    }
  },
  "description": "LLMは chapters ごとに title, purpose, scenes を生成する。number と chapter_number は engine で機械採番されるため含めない。"
}
