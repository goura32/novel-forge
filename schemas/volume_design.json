{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesign",
  "type": "object",
  "required": [
    "chapters"
  ],
  "properties": {
    "title": {
      "description": "巻タイトル",
      "type": "string"
    },
    "premise": {
      "description": "巻の前提・あらすじ",
      "type": "string"
    },
    "chapters": {
      "description": "章のリスト（3〜10章）",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "description": "章タイトル",
            "type": "string"
          },
          "purpose": {
            "description": "章の役割（導入/展開/転換/クライマックス/収束）",
            "type": "string",
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ]
          },
          "scenes": {
            "description": "シーンのリスト。1章あたり2-4シーンが標準。",
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "goal",
                "outcome"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "pov": {
                  "type": "string"
                },
                "goal": {
                  "type": "string"
                },
                "conflict": {
                  "type": "string"
                },
                "outcome": {
                  "type": "string"
                },
                "characters": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "charactersの配列"
                  }
                },
                "key_events": {
                  "description": "主要イベント",
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "key_eventsの配列"
                  }
                },
                "setting": {
                  "description": "舞台設定",
                  "type": "string"
                }
              },
              "description": "scenesの配列"
            }
          }
        },
        "description": "chaptersの配列"
      }
    }
  },
  "description": "LLMは chapters ごとに title, purpose, scenes を生成する。number と chapter_number は engine で機械採番されるため含めない。"
}