{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesign",
  "type": "object",
  "description": "LLM は chapters ごとに title, purpose を生成する。number と chapter_number は engine で機械採番されるため含めない。",
  "required": [
    "chapters"
  ],
  "properties": {
    "chapters": {
      "description": "章のリスト。2〜8個推奨。",
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "description": "章タイトル。5〜100文字推奨。",
            "type": "string",
            "minLength": 3,
            "maxLength": 200
          },
          "purpose": {
            "description": "章の役割。",
            "type": "string",
            "minLength": 1,
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ]
          }
        }
      }
    }
  }
}