{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanReview",
  "type": "object",
  "required": ["score", "issues", "strengths", "recommendations"],
  "properties": {
    "score": {
      "type": "number",
      "description": "総合評価スコア。0〜100の範囲で出力すること。"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "description", "suggestion"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"],
            "description": "問題の重大度。critical=言語制約違反や致命的欠陥、major=改善必須、minor=任意改善"
          },
          "category": {
            "type": "string",
            "description": "問題のカテゴリ名"
          },
          "description": {
            "type": "string",
            "description": "問題の説明"
          },
          "suggestion": {
            "type": "string",
            "description": "改善提案"
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "企画の強み"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "改善推奨事項"
      }
    }
  }
}
