{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanVolumes",
  "description": "シリーズ企画の各巻設計。世界観とキャラクターを踏まえて各巻のタイトルと前提を設計する。",
  "type": "object",
  "properties": {
    "planned_volumes": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 128,
            "description": "巻タイトル（128文字以内）"
          },
          "premise": {
            "type": "string",
            "maxLength": 500,
            "description": "巻のあらすじ（500文字以内）"
          },
          "theme": {
            "type": "string",
            "maxLength": 300,
            "description": "巻のテーマ（300文字以内）"
          },
          "emotional_arc": {
            "type": "string",
            "maxLength": 200,
            "description": "巻全体の感情の弧（200文字以内）"
          },
          "key_events": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 200
            },
            "minItems": 1,
            "description": "巻内の主要イベント（1個以上、各200文字以内）"
          },
          "cliffhanger": {
            "type": "string",
            "maxLength": 500,
            "description": "次巻へのフック（最終巻以外必須、500文字以内）"
          }
        }
      },
      "minItems": 1
    }
  },
  "required": [
    "planned_volumes"
  ]
}