{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanVolumes",
  "description": "シリーズ企画の各巻設計。世界観とキャラクターを踏まえて各巻のタイトルと前提を設計する。",
  "type": "object",
  "properties": {
    "planned_volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "巻タイトル（最大500文字）"
          },
          "premise": {
            "type": "string",
            "description": "巻のあらすじ（最大1000文字）"
          },
          "theme": {
            "type": "string",
            "description": "巻のテーマ（最大600文字）"
          },
          "emotional_arc": {
            "type": "string",
            "description": "巻全体の感情の弧（最大500文字）"
          },
          "key_events": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "key_eventsの配列"
            },
            "description": "巻内の主要イベント（1個以上、各最大200文字）"
          },
          "cliffhanger": {
            "type": "string",
            "description": "次巻へのフック（最終巻以外必須、最大1000文字）"
          }
        },
        "description": "巻構成一覧"
      },
      "description": "巻構成一覧（3巻固定）"
    }
  },
  "required": [
    "planned_volumes"
  ]
}