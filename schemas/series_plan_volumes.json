{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanVolumes",
  "description": "シリーズ企画の各巻設計。世界観とキャラクターを踏まえて各巻のタイトルと前提を設計する。",
  "type": "object",
  "properties": {
    "planned_volumes": {
      "description": "巻構成一覧。2〜8個推奨。",
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["title", "premise", "theme", "emotional_arc", "key_events", "cliffhanger"],
        "properties": {
          "title": {
            "description": "巻タイトル。10〜500文字推奨。",
            "type": "string"
          },
          "premise": {
            "description": "巻のあらすじ。300〜1000文字推奨。",
            "type": "string"
          },
          "theme": {
            "description": "巻のテーマ。100〜600文字推奨。",
            "type": "string"
          },
          "emotional_arc": {
            "description": "巻全体の感情の弧。100〜500文字推奨。",
            "type": "string"
          },
          "key_events": {
            "description": "巻内の主要イベント。3〜10個推奨、各最大200文字。",
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "cliffhanger": {
            "description": "次巻へのフック（最終巻以外必須）。100〜1000文字推奨。",
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "planned_volumes"
  ]
}
