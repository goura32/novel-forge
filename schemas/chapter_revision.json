{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterRevision",
  "type": "object",
  "required": [
    "title",
    "scenes"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "number",
          "title",
          "content"
        ],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "maxLength": 128
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16000
          }
        }
      }
    }
  }
}