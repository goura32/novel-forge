{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesignRevision",
  "type": "object",
  "required": [
    "title",
    "premise",
    "chapters"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "巻タイトル（想定: 500文字）"
    },
    "premise": {
      "type": "string",
      "description": "巻の前提（想定: 500文字）"
    },
    "chapters": {
      "type": "array",
      "description": "章のリスト。1巻あたり4-8章が標準。3章以下は短すぎ、10章以上は長すぎ。",
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "章タイトル"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ],
            "description": "章の役割"
          },
          "scenes": {
            "type": "array",
            "description": "シーンのリスト。1章あたり2-4シーンが標準。",
            "items": {
              "type": "object",
              "required": [
                "title",
                "goal",
                "outcome"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "description": "シーンタイトル"
                },
                "goal": {
                  "type": "string",
                  "description": "State: 状況 | Action: 行動"
                },
                "outcome": {
                  "type": "string",
                  "description": "シーン終了時の結果"
                },
                "conflict": {
                  "type": "string",
                  "description": "障害・対立"
                },
                "pov": {
                  "type": "string",
                  "description": "視点人物"
                },
                "characters": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "登場人物"
                },
                "key_events": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "主要イベント"
                },
                "setting": {
                  "type": "string",
                  "description": "舞台設定"
                }
              }
            }
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}