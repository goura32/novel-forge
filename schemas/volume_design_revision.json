{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeDesignRevision",
  "description": "巻設計の改訂用スキーマ",
  "type": "object",
  "required": [
    "chapters"
  ],
  "properties": {
    "chapters": {
      "description": "章のリスト。2〜8個推奨。",
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "title",
          "purpose"
        ],
        "properties": {
          "title": {
            "description": "章タイトル。5〜100文字推奨。",
            "type": "string"
          },
          "purpose": {
            "description": "章の役割。",
            "type": "string",
            "enum": [
              "導入",
              "展開",
              "転換",
              "クライマックス",
              "収束"
            ]
          }
        }
      }
    }
  }
}