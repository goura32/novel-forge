{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneRevision",
  "type": "object",
  "required": [
    "title",
    "content",
    "changes"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16000
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      }
    }
  }
}