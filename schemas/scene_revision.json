{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneRevision",
  "type": "object",
  "required": [
    "content"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "シーンタイトル（変更しない場合でも入力すること）"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16000,
      "description": "改稿後のシーン本文"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500,
        "description": "変更内容"
      },
      "description": "変更内容のリスト（省略可）"
    }
  }
}
