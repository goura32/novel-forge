{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterReview",
  "type": "object",
  "required": [
    "score",
    "issues",
    "revision_needed"
  ],
  "properties": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "description"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "minor",
              "major",
              "critical",
              "blocker"
            ]
          },
          "description": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "revision_needed": {
      "type": "boolean"
    }
  }
}