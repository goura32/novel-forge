{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneReview",
  "type": "object",
  "required": [
    "score",
    "dimensions",
    "issues",
    "revision_needed"
  ],
  "properties": {
    "score": {
      "type": "number",
      "description": "シーン品質スコア。0〜100の範囲で出力すること。"
    },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "score"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "評価次元名",
            "enum": [
              "opening_hook",
              "character_distinction",
              "foreshadowing_consistency",
              "sensory_coverage",
              "page_turner",
              "dialogue_naturalness",
              "tone_consistency",
              "scene_completeness",
              "language_purity",
              "pov_consistency"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "description",
          "suggestion"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "minor",
              "major",
              "critical",
              "blocker"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "opening_hook",
              "character_distinction",
              "foreshadowing_consistency",
              "sensory_coverage",
              "page_turner",
              "dialogue_naturalness",
              "tone_consistency",
              "scene_completeness",
              "language_purity",
              "pov_consistency"
            ]
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "問題の説明"
          },
          "suggestion": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 2000
            },
            "description": "具体的な修正指示のリスト。必ず1つ以上の要素を含めること。"
          }
        }
      }
    },
    "revision_needed": {
      "type": "boolean",
      "description": "改稿が必要かどうか。blocker・critical issue がある場合、または major issue が2つ以上ある場合に true。minor issue のみ、issue なし、major 1つの場合は false。"
    },
    "ready_for_publication": {
      "type": "boolean",
      "description": "出版可能かどうか"
    }
  }
}
