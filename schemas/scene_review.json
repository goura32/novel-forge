{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneReview",
  "type": "object",
  "required": [
    "issues"
  ],
  "properties": {
    "issues": {
      "description": "指摘事項の配列",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "description",
          "suggestion"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "軽微",
              "重要",
              "重大",
              "致命的"
            ]
          },
          "category": {
            "description": "指摘カテゴリ",
            "type": "string",
            "enum": [
              "冒頭フック",
              "キャラ立ち",
              "感覚描写",
              "シーン末尾",
              "台詞自然さ",
              "文体統一",
              "シーン完結",
              "シーン文字数",
              "言語純度",
              "POV一貫性"
            ]
          },
          "description": {
            "description": "問題の説明",
            "type": "string"
          },
          "suggestion": {
            "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。",
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "before",
                "after"
              ],
              "properties": {
                "before": {
                  "description": "修正前のテキスト（該当箇所を引用）",
                  "type": "string"
                },
                "after": {
                  "description": "修正後のテキスト",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}