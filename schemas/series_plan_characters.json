{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharacters",
  "description": "シリーズ企画のキャラクター設計。世界観とシリーズ企画に基づくメインキャラクターの詳細設定。",
  "type": "object",
  "properties": {
    "main_characters": {
      "description": "メインキャラクター。3〜5個推奨。最低3人。",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "personality",
          "motivation",
          "flaw",
          "arc",
          "occupation",
          "appearance",
          "background"
        ],
        "properties": {
          "name": {
            "description": "キャラクター名",
            "type": "string"
          },
          "role": {
            "description": "役割（主人公の恩師、ライバル、相棒など具体的に）",
            "type": "string"
          },
          "personality": {
            "description": "性格・気質",
            "type": "string"
          },
          "motivation": {
            "description": "動機・目的",
            "type": "string"
          },
          "flaw": {
            "description": "欠点・弱点",
            "type": "string"
          },
          "arc": {
            "description": "成長の方向性・軌跡",
            "type": "string"
          },
          "occupation": {
            "description": "職業・立場",
            "type": "string"
          },
          "appearance": {
            "description": "外見的特徴",
            "type": "string"
          },
          "background": {
            "description": "背景・来歴",
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "main_characters"
  ]
}