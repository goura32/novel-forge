{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharacters",
  "description": "シリーズ企画のキャラクター設計。世界観を踏まえてメインキャラクターを設計する。",
  "type": "object",
  "properties": {
    "main_characters": {
      "description": "メインキャラクター（1人以上）",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": {
            "description": "キャラクター名（フルネーム、最大64文字）",
            "type": "string"
          },
          "role": {
            "description": "役割（具体的に記述。最大64文字）",
            "type": "string"
          },
          "personality": {
            "description": "性格・特徴（最大200文字）",
            "type": "string"
          },
          "motivation": {
            "description": "動機・目標（最大200文字）",
            "type": "string"
          },
          "flaw": {
            "description": "欠点・弱み（最大200文字）",
            "type": "string"
          },
          "arc": {
            "description": "シリーズを通じた成長・変化（最大500文字）",
            "type": "string"
          },
          "age": {
            "description": "年齢（最大32文字）",
            "type": "string"
          },
          "occupation": {
            "description": "職業・立場（最大128文字）",
            "type": "string"
          },
          "appearance": {
            "description": "外見的特徴（最大200文字）",
            "type": "string"
          },
          "background": {
            "description": "過去・経歴（最大500文字）",
            "type": "string"
          }
        },
        "description": "main_charactersの配列"
      }
    }
  },
  "required": [
    "main_characters"
  ]
}