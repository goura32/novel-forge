{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharacters",
  "description": "シリーズ企画のキャラクター設計。世界観を踏まえてメインキャラクターを設計する。",
  "type": "object",
  "properties": {
    "main_characters": {
      "description": "メインキャラクター。3〜5個推奨。",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": {
            "description": "キャラクター名。2〜64文字。",
            "type": "string"
          },
          "role": {
            "description": "役割。具体的に記述。10〜128文字。",
            "type": "string"
          },
          "personality": {
            "description": "性格・特徴。50〜300文字推奨。",
            "type": "string"
          },
          "motivation": {
            "description": "動機・目標。50〜300文字推奨。",
            "type": "string"
          },
          "flaw": {
            "description": "欠点・弱み。30〜200文字推奨。",
            "type": "string"
          },
          "arc": {
            "description": "シリーズを通じた成長・変化。100〜500文字推奨。",
            "type": "string"
          },
          "age": {
            "description": "年齢。",
            "type": "string"
          },
          "occupation": {
            "description": "職業・立場。5〜128文字推奨。",
            "type": "string"
          },
          "appearance": {
            "description": "外見的特徴。20〜200文字推奨。",
            "type": "string"
          },
          "background": {
            "description": "過去・経歴。50〜500文字推奨。",
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "main_characters"
  ]
}
