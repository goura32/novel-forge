{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharacters",
  "description": "シリーズ企画のキャラクター設計。世界観を踏まえてメインキャラクターを設計する。",
  "type": "object",
  "required": ["main_characters"],
  "properties": {
    "main_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "arc", "gender", "age", "occupation", "personality", "appearance", "background", "motivation", "flaw", "growth"],
        "properties": {
          "name": { "type": "string", "maxLength": 64, "description": "キャラクター名（フルネーム）" },
          "role": { "type": "string", "enum": ["主人公", "ヒロイン", "相棒", "敵対者", "師匠", "仲間"], "description": "役割" },
          "arc": { "type": "string", "maxLength": 300, "description": "シリーズを通じた成長・変化" },
          "gender": { "type": "string", "enum": ["男性", "女性", "その他"], "description": "性別" },
          "age": { "type": "string", "maxLength": 32, "description": "年齢（例: 28歳）" },
          "occupation": { "type": "string", "maxLength": 128, "description": "職業・立場" },
          "personality": { "type": "string", "maxLength": 300, "description": "性格・特徴" },
          "appearance": { "type": "string", "maxLength": 200, "description": "外見的特徴" },
          "background": { "type": "string", "maxLength": 300, "description": "過去・経歴" },
          "motivation": { "type": "string", "maxLength": 200, "description": "動機・目標" },
          "flaw": { "type": "string", "maxLength": 200, "description": "欠点・弱み" },
          "growth": { "type": "string", "maxLength": 200, "description": "成長の方向性" }
        }
      },
      "minItems": 2
    }
  }
}
