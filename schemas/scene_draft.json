{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDraft",
  "type": "object",
  "required": [
    "title",
    "content"
  ],
  "properties": {
    "title": {
      "description": "シーンタイトル（最大128文字）",
      "type": "string"
    },
    "content": {
      "description": "シーンの本文（目安3000-6000文字。シーンの性質に応じて増減）",
      "type": "string",
      "minLength": 1000
    }
  }
}