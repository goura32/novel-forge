{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDraft",
  "type": "object",
  "required": [
    "title",
    "content"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "シーンタイトル（最大128文字）"
    },
    "content": {
      "type": "string",
      "description": "シーンの本文（最低3000文字以上）"
    }
  }
}