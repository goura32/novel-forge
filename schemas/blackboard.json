{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blackboard",
  "type": "object",
  "required": [
    "facts",
    "scene_summaries"
  ],
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate",
          "object",
          "confidence"
        ],
        "properties": {
          "subject": {
            "type": "string",
            "description": "主語"
          },
          "predicate": {
            "type": "string",
            "description": "述語"
          },
          "object": {
            "type": "string",
            "description": "目的語"
          },
          "confidence": {
            "type": "number"
          }
        },
        "description": "事実記録"
      },
      "description": "事実記録"
    },
    "scene_summaries": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "シーン要約の辞書。キーはシーン番号（文字列）、値は要約"
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "連続性メモ"
      },
      "description": "連続性メモ"
    }
  }
}