{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blackboard",
  "type": "object",
  "required": [
    "facts",
    "scene_summaries"
  ],
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate"
        ],
        "properties": {
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "scene_summaries": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "maxLength": 1000
      }
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      }
    }
  }
}