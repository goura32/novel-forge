{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesignRevision",
  "description": "シーン設計の改訂結果",
  "type": "object",
  "required": [
    "title",
    "goal",
    "outcome"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 500,
      "description": "シーンタイトル（500文字以内）"
    },
    "goal": {
      "type": "string",
      "maxLength": 800,
      "description": "State: 状況 | Action: 行動（800文字以内）"
    },
    "outcome": {
      "type": "string",
      "maxLength": 800,
      "description": "シーン終了時の結果（800文字以内）"
    },
    "conflict": {
      "type": "string",
      "maxLength": 600,
      "description": "障害・対立（600文字以内）"
    },
    "pov": {
      "type": "string",
      "maxLength": 500,
      "description": "視点人物（500文字以内）"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "description": "登場人物（各64文字以内）"
    },
    "key_events": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "description": "主要イベント（各200文字以内）"
    },
    "setting": {
      "type": "string",
      "maxLength": 500,
      "description": "舞台設定（500文字以内）"
    },
    "emotional_arc": {
      "type": "string",
      "maxLength": 500,
      "description": "感情の弧（500文字以内）"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}