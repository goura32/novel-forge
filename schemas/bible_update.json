{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BibleUpdate",
  "type": "object",
  "properties": {
    "foreshadowing": {
      "description": "伏線リスト",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "一意識別子",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "設置",
              "回収"
            ]
          },
          "resolved": {
            "type": "boolean"
          },
          "scene_number": {
            "description": "番号",
            "type": "integer"
          }
        },
        "description": "更新された伏線"
      }
    },
    "characters": {
      "description": "キャラクター",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "personality": {
            "type": "string"
          },
          "appearance": {
            "type": "string"
          },
          "motivation": {
            "type": "string"
          },
          "arc": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "is_new": {
            "type": "boolean"
          }
        },
        "description": "更新されたキャラクター"
      }
    },
    "relationships": {
      "description": "キャラクター関係",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "character_a": {
            "type": "string"
          },
          "character_b": {
            "type": "string"
          },
          "relationship_type": {
            "type": "string"
          },
          "change_direction": {
            "type": "string",
            "enum": [
              "改善",
              "悪化",
              "変化",
              "変化なし"
            ]
          },
          "trigger_event": {
            "type": "string"
          }
        },
        "description": "更新された関係"
      }
    },
    "subplots": {
      "description": "サブプロット",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "一意識別子",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "未着手",
              "進行中",
              "完了"
            ]
          },
          "progress_note": {
            "type": "string"
          }
        },
        "description": "更新されたサブプロット"
      }
    },
    "glossary": {
      "description": "用語集",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "is_new": {
            "type": "boolean"
          }
        },
        "description": "更新された用語"
      }
    },
    "world_rules": {
      "description": "世界観ルール",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": {
            "type": "string"
          },
          "is_new": {
            "type": "boolean"
          }
        },
        "description": "更新された世界観ルール"
      }
    },
    "facts": {
      "description": "事実記録",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        },
        "description": "新しく抽出した事実"
      }
    },
    "continuity_notes": {
      "description": "連続性メモ",
      "type": "array",
      "items": {
        "type": "string",
        "description": "連続性メモ"
      }
    }
  }
}