{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KdpMetadata",
  "type": "object",
  "required": [
    "title",
    "description",
    "keywords",
    "categories"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "タイトル"
    },
    "subtitle": {
      "type": "string",
      "maxLength": 128,
      "description": "サブタイトル"
    },
    "series_name": {
      "type": "string",
      "maxLength": 128,
      "description": "シリーズ名"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "商品説明"
    },
    "back_cover_text": {
      "type": "string",
      "maxLength": 1000,
      "description": "裏表紙テキスト"
    },
    "target_audience": {
      "type": "string",
      "maxLength": 50,
      "description": "ターゲット読者"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 32,
        "description": "キーワード"
      },
      "maxItems": 7
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64,
        "description": "カテゴリ"
      },
      "minItems": 1,
      "maxItems": 2
    },
    "content_warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64,
        "description": "コンテンツ警告"
      }
    },
    "author_note": {
      "type": "string",
      "maxLength": 500,
      "description": "著者ノート"
    }
  }
}
