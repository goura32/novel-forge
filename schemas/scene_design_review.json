{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesignReview",
  "description": "シーン設計の自己レビュー結果",
  "type": "object",
  "required": [
    "issues"
  ],
  "properties": {
    "issues": {
      "type": "array",
      "description": "指摘事項の配列",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "description",
          "affected_elements"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "致命的",
              "重大",
              "重要",
              "軽微"
            ],
            "description": "修正の緊急性。致命的・重大=必須修正、重要=強推奨、軽微=任意。"
          },
          "category": {
            "type": "string",
            "enum": [
              "必須フィールド欠落",
              "目標結果の整合性",
              "葛藤の質",
              "舞台設定完了性",
              "シーン多様性"
            ],
            "description": "指摘のカテゴリ。"
          },
          "description": {
            "type": "string",
            "description": "問題の具体的な説明。何がなぜ問題か、どのような影響があるかを具体的に記述する。"
          },
          "affected_elements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "問題が特定の要素に関わる場合、該当名（キャラクター名・シーン番号等）を列挙。"
          },
          "suggestion": {
            "type": "array",
            "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。",
            "items": {
              "type": "object",
              "required": [
                "before",
                "after"
              ],
              "properties": {
                "before": {
                  "type": "string",
                  "description": "修正前のテキスト（該当箇所を引用）"
                },
                "after": {
                  "type": "string",
                  "description": "修正後のテキスト"
                }
              }
            }
          }
        }
      }
    }
  }
}
