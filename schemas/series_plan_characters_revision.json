{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharactersRevision",
  "description": "シリーズ企画（キャラクター）の改訂結果",
  "type": "object",
  "required": [
    "main_characters",
    "changes"
  ],
  "properties": {
    "main_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "arc"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 64,
            "description": "キャラクター名（フルネーム、64文字以内）"
          },
          "role": {
            "type": "string",
            "description": "役割（例: 主人公、ヒロイン、相棒、敵対者、師匠、仲間、調停者、観察者等）"
          },
          "arc": {
            "type": "string",
            "maxLength": 300,
            "description": "シリーズを通じた成長・変化（300文字以内）"
          },
          "age": {
            "type": "string",
            "maxLength": 32,
            "description": "年齢（例: 28歳、32文字以内）"
          },
          "occupation": {
            "type": "string",
            "maxLength": 128,
            "description": "職業・立場（128文字以内）"
          },
          "personality": {
            "type": "string",
            "maxLength": 500,
            "description": "性格・特徴（500文字以内）"
          },
          "appearance": {
            "type": "string",
            "maxLength": 200,
            "description": "外見的特徴（200文字以内）"
          },
          "background": {
            "type": "string",
            "maxLength": 500,
            "description": "過去・経歴（500文字以内）"
          },
          "motivation": {
            "type": "string",
            "maxLength": 500,
            "description": "動機・目標（500文字以内）"
          },
          "flaw": {
            "type": "string",
            "maxLength": 500,
            "description": "欠点・弱み（500文字以内）"
          },
          "growth": {
            "type": "string",
            "maxLength": 500,
            "description": "成長の方向性（500文字以内）"
          }
        }
      },
      "minItems": 2,
      "maxItems": 5,
      "description": "メインキャラクター（2-5人）"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 500,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 500,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}
