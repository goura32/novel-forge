{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCharactersRevision",
  "description": "シリーズ企画（キャラクター）の改訂結果",
  "type": "object",
  "required": [
    "main_characters",
    "changes"
  ],
  "properties": {
    "main_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "arc"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 64,
            "description": "キャラクター名（フルネーム）"
          },
          "role": {
            "type": "string",
            "enum": [
              "主人公",
              "ヒロイン",
              "相棒",
              "敵対者",
              "師匠",
              "仲間"
            ]
          },
          "arc": {
            "type": "string",
            "maxLength": 300,
            "description": "シリーズを通じた成長・変化"
          },
          "gender": {
            "type": "string",
            "enum": [
              "男性",
              "女性",
              "その他"
            ]
          },
          "age": {
            "type": "string",
            "maxLength": 32
          },
          "occupation": {
            "type": "string",
            "maxLength": 128
          },
          "personality": {
            "type": "string",
            "maxLength": 500,
            "description": "性格・特徴"
          },
          "appearance": {
            "type": "string",
            "maxLength": 200
          },
          "background": {
            "type": "string",
            "maxLength": 500,
            "description": "過去・経歴"
          },
          "motivation": {
            "type": "string",
            "maxLength": 500,
            "description": "動機・目標"
          },
          "flaw": {
            "type": "string",
            "maxLength": 500,
            "description": "欠点・弱み"
          },
          "growth": {
            "type": "string",
            "maxLength": 500,
            "description": "成長の方向性"
          }
        }
      },
      "minItems": 2,
      "maxItems": 5
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 200,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 200,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}
