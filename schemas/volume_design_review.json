{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OutlineReview",
  "description": "巻デザインの自己レビュー結果",
  "type": "object",
  "required": [
    "issues"
  ],
  "properties": {
    "issues": {
      "description": "指摘事項の配列",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "description",
          "affected_elements"
        ],
        "properties": {
          "severity": {
            "description": "修正の緊急性。致命的・重大=必須修正、重要=強推奨、軽微=任意。",
            "type": "string",
            "enum": [
              "致命的",
              "重大",
              "重要",
              "軽微"
            ]
          },
          "category": {
            "description": "指摘のカテゴリ。必須フィールド、構成、一貫性、ペース。",
            "type": "string",
            "enum": [
              "必須フィールド",
              "必須フィールド欠落",
              "構成",
              "構成の妥当性",
              "一貫性",
              "シーン一貫性",
              "ペース",
              "ペース配分"
            ]
          },
          "description": {
            "description": "問題の説明",
            "type": "string"
          },
          "affected_elements": {
            "description": "問題が特定の要素に関わる場合、該当名を列挙。",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggestion": {
            "description": "修正の提案。",
            "type": "string"
          }
        }
      }
    }
  }
}
