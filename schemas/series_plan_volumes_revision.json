{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanVolumesRevision",
  "description": "シリーズ企画（各巻）の改訂結果",
  "type": "object",
  "required": [
    "planned_volumes",
    "changes"
  ],
  "properties": {
    "planned_volumes": {
      "type": "array",
      "description": "各巻の計画（3巻固定）",
      "items": {
        "type": "object",
        "required": [
          "title",
          "premise"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 500,
            "description": "巻タイトル（500文字以内）"
          },
          "premise": {
            "type": "string",
            "maxLength": 1000,
            "description": "巻のあらすじ（1000文字以内）"
          },
          "theme": {
            "type": "string",
            "maxLength": 600,
            "description": "巻のテーマ（600文字以内）"
          },
          "emotional_arc": {
            "type": "string",
            "maxLength": 500,
            "description": "巻全体の感情の弧（500文字以内）"
          },
          "key_events": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 500
            },
            "description": "巻内の主要イベント（各200文字以内）"
          },
          "cliffhanger": {
            "type": "string",
            "maxLength": 1000,
            "description": "次巻へのフック（最終巻以外必須、1000文字以内）"
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}