{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RevisionPriority",
  "type": "object",
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_chapter",
          "priority",
          "reason"
        ],
        "properties": {
          "target_chapter": {
            "type": "integer",
            "minimum": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "reason": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    }
  }
}