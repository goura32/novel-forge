{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanRevision",
  "type": "object",
  "required": [
    "title",
    "logline",
    "genre",
    "target_audience",
    "themes",
    "selling_points",
    "world",
    "main_characters",
    "planned_volumes"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128
    },
    "logline": {
      "type": "string",
      "maxLength": 200
    },
    "genre": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "minItems": 1,
      "maxItems": 3,
      "description": "ジャンル（1-3個）"
    },
    "target_audience": {
      "type": "string",
      "maxLength": 200
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selling_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "world": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 500
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "main_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 64
          },
          "role": {
            "type": "string",
            "maxLength": 64
          },
          "arc": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "planned_volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "title": {
            "type": "string",
            "maxLength": 128
          },
          "premise": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "premise": {
      "type": "string",
      "description": "シリーズの前提"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 32
      },
      "description": "キーワード"
    },
    "catchphrase": {
      "type": "string",
      "description": "キャッチコピー"
    },
    "differentiation": {
      "type": "string",
      "description": "差別化ポイント"
    }
  }
}
