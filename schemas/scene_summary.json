{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummary",
  "type": "object",
  "required": [
    "summary",
    "characters",
    "facts"
  ],
  "properties": {
    "summary": {
      "description": "シーンの要約",
      "type": "string"
    },
    "characters": {
      "description": "登場キャラクター",
      "type": "array",
      "items": {
        "type": "string",
        "description": "charactersの配列"
      }
    },
    "facts": {
      "description": "抽出事実",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate",
          "object"
        ],
        "properties": {
          "subject": {
            "description": "主語",
            "type": "string"
          },
          "predicate": {
            "description": "述語",
            "type": "string"
          },
          "object": {
            "description": "目的語",
            "type": "string"
          }
        },
        "description": "factsの配列"
      }
    },
    "continuity_notes": {
      "description": "連続性メモ",
      "type": "array",
      "items": {
        "type": "string",
        "description": "連続性メモ"
      }
    }
  }
}