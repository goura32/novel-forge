{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummary",
  "type": "object",
  "required": [
    "summary",
    "characters",
    "facts"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "maxLength": 1000,
      "description": "シーンの要約"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate",
          "object"
        ],
        "properties": {
          "subject": {
            "type": "string",
            "description": "主語"
          },
          "predicate": {
            "type": "string",
            "description": "述語"
          },
          "object": {
            "type": "string",
            "description": "目的語"
          }
        }
      }
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200,
        "description": "連続性メモ"
      }
    }
  }
}
