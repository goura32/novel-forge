{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummary",
  "type": "object",
  "required": [
    "summary",
    "characters",
    "facts"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "maxLength": 1000
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate"
        ],
        "properties": {
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        }
      }
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      }
    }
  }
}