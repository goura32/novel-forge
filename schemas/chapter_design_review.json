{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review",
  "description": "自己レビュー結果",
  "type": "object",
  "required": [
    "issues"
  ],
  "properties": {
    "issues": {
      "description": "指摘事項のリスト",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "description",
          "suggestion",
          "before",
          "after"
        ],
        "properties": {
          "severity": {
            "description": "修正の緊急性。致命的=必須修正、重大=必須修正、重要=強推奨、軽微=任意。",
            "type": "string",
            "enum": [
              "致命的",
              "重大",
              "重要",
              "軽微"
            ]
          },
          "category": {
            "description": "指摘のカテゴリ。",
            "type": "string",
            "enum": [
              "必須フィールド",
              "章役割",
              "テーマ",
              "感情弧",
              "シーン配分"
            ]
          },
          "description": {
            "description": "問題の説明",
            "type": "string"
          },
          "suggestion": {
            "description": "修正の提案（自由記述）",
            "type": "string"
          },
          "before": {
            "description": "修正前のテキスト（該当箇所を引用）",
            "type": "string"
          },
          "after": {
            "description": "修正後のテキスト",
            "type": "string"
          }
        }
      }
    }
  }
}