{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "required": ["number", "title", "pov", "goal", "conflict", "outcome", "characters", "emotional_arc", "key_events", "setting"],
  "properties": {
    "number": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "maxLength": 128 },
    "pov": { "type": "string", "maxLength": 64 },
    "goal": { "type": "string", "description": "MVME: (State > Action | Result)" },
    "conflict": { "type": "string", "maxLength": 200 },
    "outcome": { "type": "string", "maxLength": 200 },
    "characters": { "type": "array", "items": { "type": "string", "maxLength": 64 } },
    "emotional_arc": { "type": "string", "maxLength": 200 },
    "key_events": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
    "setting": { "type": "string", "maxLength": 200 },
    "notes": { "type": "string", "maxLength": 500 }
  }
}
