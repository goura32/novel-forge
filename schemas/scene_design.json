{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "required": [
    "title",
    "goal",
    "outcome",
    "conflict",
    "pov",
    "characters",
    "key_events",
    "setting"
  ],
  "properties": {
    "title": {
      "description": "シーンタイトル（3〜100文字推奨）",
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "goal": {
      "description": "シーン開始時の状況と主人公の行動（20〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "outcome": {
      "description": "シーン終了時の実際の結果（20〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "conflict": {
      "description": "シーン内の障害・対立（20〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "pov": {
      "description": "視点人物",
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "characters": {
      "description": "登場人物（1〜10個推奨）",
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "key_events": {
      "description": "主要イベント（1〜5個推奨）",
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      }
    },
    "setting": {
      "description": "舞台設定（20〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    }
  },
  "description": "シーンの詳細設計。1シーン毎に生成される。デザインであり、シーンの目標・結果・葛藤・POV・キャラクター・キーイベント・設定を含む詳細設計書。"
}