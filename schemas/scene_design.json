{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "required": [
    "title",
    "goal",
    "outcome"
  ],
  "properties": {
    "title": {
      "description": "シーンタイトル",
      "type": "string"
    },
    "goal": {
      "description": "シーン開始時の状況と主人公の行動",
      "type": "string"
    },
    "outcome": {
      "description": "シーン終了時の実際の結果",
      "type": "string"
    },
    "conflict": {
      "description": "シーン内の障害・対立",
      "type": "string"
    },
    "pov": {
      "description": "視点人物",
      "type": "string"
    },
    "characters": {
      "description": "登場人物",
      "type": "array",
      "items": {
        "type": "string",
        "description": "charactersの配列"
      }
    },
    "key_events": {
      "description": "主要イベント",
      "type": "array",
      "items": {
        "type": "string",
        "description": "key_eventsの配列"
      }
    },
    "setting": {
      "description": "舞台設定",
      "type": "string"
    }
  },
  "description": "シーンの詳細設計。1シーン毎に生成される。デザインであり、シーンの目標・結果・葛藤・POV・キャラクター・キーイベント・設定を含む詳細設計書。"
}