{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "required": ["title", "goal", "outcome"],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "シーンタイトル"
    },
    "goal": {
      "type": "string",
      "maxLength": 400,
      "description": "シーン開始時の状況と主人公の行動"
    },
    "outcome": {
      "type": "string",
      "maxLength": 400,
      "description": "シーン終了時の実際の結果"
    },
    "conflict": {
      "type": "string",
      "maxLength": 300,
      "description": "シーン内の障害・対立"
    },
    "pov": {
      "type": "string",
      "maxLength": 64,
      "description": "視点人物"
    },
    "characters": {
      "type": "array",
      "items": { "type": "string", "maxLength": 64 },
      "description": "登場人物"
    },
    "key_events": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "description": "主要イベント"
    },
    "setting": {
      "type": "string",
      "maxLength": 200,
      "description": "舞台設定"
    }
  },
  "description": "シーンの詳細設計。1シーン毎に生成される。アウトラインではなく、シーンの目標・結果・葛藤・POV・キャラクター・キーイベント・設定を含む詳細設計書。"
}
