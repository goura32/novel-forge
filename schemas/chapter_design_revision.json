{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesignRevision",
  "description": "章設計の改訂結果",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 500,
      "description": "章タイトル（500文字以内）"
    },
    "purpose": {
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ],
      "description": "章の役割（「導入」「展開」「転換」「クライマックス」「収束」から選択）"
    },
    "theme": {
      "type": "string",
      "maxLength": 600,
      "description": "章のテーマ（600文字以内）"
    },
    "emotional_arc": {
      "type": "string",
      "maxLength": 600,
      "description": "感情の弧（600文字以内）"
    },
    "foreshadowing_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 600
      },
      "description": "伏線メモ（各300文字以内）"
    },
    "subplot_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 600
      },
      "description": "サブプロットメモ（各300文字以内）"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 1000,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}