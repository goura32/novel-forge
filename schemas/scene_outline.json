{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneDesign",
  "type": "object",
  "required": ["title", "goal", "outcome"],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "シーンタイトル"
    },
    "goal": {
      "type": "string",
      "description": "シーン開始時の目標。State: 開始時の状況、Action: 主人公の行動。結果は outcome に書くため、goal には含めない。"
    },
    "outcome": {
      "type": "string",
      "maxLength": 500,
      "description": "シーン終了時の実際の結果。次のシーンの goal（State部分）に繋がること。必ず記述すること。"
    },
    "conflict": {
      "type": "string",
      "maxLength": 300,
      "description": "シーン内の葛藤"
    },
    "pov": {
      "type": "string",
      "maxLength": 64,
      "description": "視点人物"
    },
    "characters": {
      "type": "array",
      "items": { "type": "string", "maxLength": 64 },
      "description": "登場人物"
    },
    "key_events": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "description": "主要イベント"
    },
    "setting": {
      "type": "string",
      "maxLength": 200,
      "description": "舞台設定"
    }
  },
  "description": "シーンの詳細設計。1シーン毎に生成される。"
}
