{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc"
  ],
  "properties": {
    "title": {
      "description": "章タイトル",
      "type": "string"
    },
    "purpose": {
      "description": "章の役割。単語のみ",
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ]
    },
    "theme": {
      "description": "章のテーマ",
      "type": "string"
    },
    "emotional_arc": {
      "description": "感情の弧",
      "type": "string"
    },
    "foreshadowing_notes": {
      "description": "伏線メモのリスト",
      "type": "array",
      "items": {
        "type": "string",
        "description": "foreshadowing_notesの配列"
      }
    },
    "subplot_notes": {
      "description": "サブプロットメモのリスト",
      "type": "array",
      "items": {
        "type": "string",
        "description": "subplot_notesの配列"
      }
    }
  },
  "description": "章の詳細設計。章の役割、テーマ、感情アーク、伏線・サブプロットの扱いを定義する。"
}