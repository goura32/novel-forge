{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc",
    "outcome",
    "scenes"
  ],
  "properties": {
    "title": {
      "description": "章タイトル（5〜100文字推奨）",
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "purpose": {
      "description": "章の役割。単語のみ",
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ]
    },
    "theme": {
      "description": "章のテーマ（20〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "emotional_arc": {
      "description": "感情の弧（30〜500文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "outcome": {
      "description": "章の結果・結末（30〜300文字推奨）",
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "scenes": {
      "description": "シーンのリスト。2〜4個推奨。",
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "title",
          "pov",
          "goal",
          "conflict",
          "outcome",
          "characters",
          "key_events",
          "setting"
        ],
        "properties": {
          "title": {
            "description": "シーンタイトル。3〜100文字推奨。",
            "type": "string",
            "minLength": 3,
            "maxLength": 200
          },
          "pov": {
            "description": "視点（誰の視点で描くか）",
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "goal": {
            "description": "シーンの目標（20〜300文字推奨）",
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "conflict": {
            "description": "シーンの葛藤（20〜300文字推奨）",
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "outcome": {
            "description": "シーンの結果（20〜300文字推奨）",
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "characters": {
            "description": "登場キャラクター。1〜10個推奨。",
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "key_events": {
            "description": "主要イベント。1〜5個推奨。",
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          },
          "setting": {
            "description": "舞台設定（20〜300文字推奨）",
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          }
        }
      }
    }
  }
}