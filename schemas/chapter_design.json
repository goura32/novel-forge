{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc",
    "outcome",
    "scenes",
    "chapter_turning_point",
    "chapter_hook",
    "foreshadowing_notes",
    "subplot_notes"
  ],
  "properties": {
    "title": {
      "description": "章タイトル（5〜100文字推奨）",
      "type": "string"
    },
    "purpose": {
      "description": "目的。物語上の機能や状態が分かる具体的な日本語で書く。",
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ]
    },
    "theme": {
      "description": "章のテーマ（20〜300文字推奨）",
      "type": "string"
    },
    "emotional_arc": {
      "description": "感情の弧（30〜500文字推奨）",
      "type": "string"
    },
    "outcome": {
      "description": "章の結果・結末（30〜300文字推奨）",
      "type": "string"
    },
    "scenes": {
      "description": "シーンのリスト。2〜4個推奨。",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "pov",
          "goal",
          "conflict",
          "outcome",
          "characters",
          "key_events",
          "setting"
        ],
        "properties": {
          "title": {
            "description": "シーンタイトル。3〜100文字推奨。",
            "type": "string"
          },
          "pov": {
            "description": "視点（誰の視点で描くか）",
            "type": "string"
          },
          "goal": {
            "description": "シーンの目標（20〜300文字推奨）",
            "type": "string"
          },
          "conflict": {
            "description": "シーンの葛藤（20〜300文字推奨）",
            "type": "string"
          },
          "outcome": {
            "description": "シーンの結果（20〜300文字推奨）",
            "type": "string"
          },
          "characters": {
            "description": "登場キャラクター。1〜10個推奨。",
            "type": "array",
            "items": {
              "type": "string",
              "description": "登場人物。登場人物の文脈で後続の設計・執筆に使える具体的な日本語で書く。"
            }
          },
          "key_events": {
            "description": "主要イベント。1〜5個推奨。",
            "type": "array",
            "items": {
              "type": "string",
              "description": "key events。key eventsの文脈で後続の設計・執筆に使える具体的な日本語で書く。"
            }
          },
          "setting": {
            "description": "舞台設定（20〜300文字推奨）",
            "type": "string"
          },
          "scene_function": {
            "description": "setup/confrontation/reversal/payoff/aftermath/reveal等のシーン機能。",
            "type": "string"
          },
          "emotional_shift": {
            "description": "このシーンで変化する感情。",
            "type": "string"
          },
          "hook": {
            "description": "hook。シーンの文脈で後続の設計・執筆に使える具体的な日本語で書く。",
            "type": "string"
          },
          "turning_point": {
            "description": "転換点。シーンの文脈で後続の設計・執筆に使える具体的な日本語で書く。",
            "type": "string"
          },
          "ending_hook": {
            "description": "末尾フック。シーンの文脈で後続の設計・執筆に使える具体的な日本語で書く。",
            "type": "string"
          }
        },
        "description": "シーンを構造化して表すオブジェクト。関連する下位フィールドを具体的に埋める。",
        "additionalProperties": false
      }
    },
    "chapter_turning_point": {
      "description": "章内で不可逆に変わる出来事・関係・認識。",
      "type": "string"
    },
    "chapter_hook": {
      "description": "章末で次章へ読ませる引き・余韻。",
      "type": "string"
    },
    "foreshadowing_notes": {
      "description": "章で設置・回収する伏線メモ。",
      "type": "array",
      "items": {
        "type": "string",
        "description": "foreshadowing notes。foreshadowing notesの文脈で後続の設計・執筆に使える具体的な日本語で書く。"
      }
    },
    "subplot_notes": {
      "description": "章で進行するサブプロットメモ。",
      "type": "array",
      "items": {
        "type": "string",
        "description": "subplot notes。subplot notesの文脈で後続の設計・執筆に使える具体的な日本語で書く。"
      }
    },
    "characters": {
      "description": "登場人物の一覧。後続工程で矛盾確認や生成に使える具体的な値を要素として入れる。",
      "type": "array",
      "items": {
        "type": "string",
        "description": "登場人物。登場人物の文脈で後続の設計・執筆に使える具体的な日本語で書く。"
      }
    }
  },
  "additionalProperties": false
}
