{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": ["number", "title", "theme", "scene_summaries", "emotional_arc", "purpose", "act_role", "characters"],
  "properties": {
    "number": { "type": "integer", "minimum": 1 },
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "章タイトル"
    },
    "theme": {
      "type": "string",
      "maxLength": 200,
      "description": "章のテーマ"
    },
    "scene_summaries": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500,
        "description": "シーン要約"
      }
    },
    "emotional_arc": {
      "type": "string",
      "maxLength": 200,
      "description": "感情の弧"
    },
    "purpose": {
      "type": "string",
      "enum": ["導入", "展開", "転換", "クライマックス", "収束"],
      "description": "章の役割。日本語で指定"
    },
    "act_role": {
      "type": "string",
      "enum": ["序盤", "中盤", "終盤"],
      "description": "三幕構成の役割。日本語で指定"
    },
    "characters": {
      "type": "array",
      "items": { "type": "string", "maxLength": 64 }
    }
  }
}
