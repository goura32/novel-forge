{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc",
    "outcome",
    "scenes",
    "chapter_turning_point",
    "chapter_hook",
    "foreshadowing_notes",
    "subplot_notes"
  ],
  "properties": {
    "title": {
      "description": "章タイトル（5〜100文字推奨）",
      "type": "string"
    },
    "purpose": {
      "description": "章の役割。単語のみ",
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ]
    },
    "theme": {
      "description": "章のテーマ（20〜300文字推奨）",
      "type": "string"
    },
    "emotional_arc": {
      "description": "感情の弧（30〜500文字推奨）",
      "type": "string"
    },
    "outcome": {
      "description": "章の結果・結末（30〜300文字推奨）",
      "type": "string"
    },
    "scenes": {
      "description": "シーンのリスト。2〜4個推奨。",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "pov",
          "goal",
          "conflict",
          "outcome",
          "characters",
          "key_events",
          "setting"
        ],
        "properties": {
          "title": {
            "description": "シーンタイトル。3〜100文字推奨。",
            "type": "string"
          },
          "pov": {
            "description": "視点（誰の視点で描くか）",
            "type": "string"
          },
          "goal": {
            "description": "シーンの目標（20〜300文字推奨）",
            "type": "string"
          },
          "conflict": {
            "description": "シーンの葛藤（20〜300文字推奨）",
            "type": "string"
          },
          "outcome": {
            "description": "シーンの結果（20〜300文字推奨）",
            "type": "string"
          },
          "characters": {
            "description": "登場キャラクター。1〜10個推奨。",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_events": {
            "description": "主要イベント。1〜5個推奨。",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "setting": {
            "description": "舞台設定（20〜300文字推奨）",
            "type": "string"
          },
          "scene_function": {
            "description": "setup/confrontation/reversal/payoff/aftermath/reveal等のシーン機能。",
            "type": "string"
          },
          "emotional_shift": {
            "description": "このシーンで変化する感情。",
            "type": "string"
          },
          "hook": {
            "description": "シーン冒頭のフック。",
            "type": "string"
          },
          "turning_point": {
            "description": "シーン内の転換点。",
            "type": "string"
          },
          "ending_hook": {
            "description": "シーン末尾の引き。",
            "type": "string"
          }
        }
      }
    },
    "chapter_turning_point": {
      "description": "章内で不可逆に変わる出来事・関係・認識。",
      "type": "string"
    },
    "chapter_hook": {
      "description": "章末で次章へ読ませる引き・余韻。",
      "type": "string"
    },
    "foreshadowing_notes": {
      "description": "章で設置・回収する伏線メモ。",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subplot_notes": {
      "description": "章で進行するサブプロットメモ。",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "characters": {
      "description": "章で重要な人物。",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
