{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterDesign",
  "type": "object",
  "required": [
    "title",
    "purpose",
    "theme",
    "emotional_arc"
  ],
  "properties": {
    "title": {
      "description": "章タイトル",
      "type": "string"
    },
    "purpose": {
      "description": "章の役割。単語のみ",
      "type": "string",
      "enum": [
        "導入",
        "展開",
        "転換",
        "クライマックス",
        "収束"
      ]
    },
    "theme": {
      "description": "章のテーマ",
      "type": "string"
    },
    "emotional_arc": {
      "description": "感情の弧",
      "type": "string"
    },
    "scenes": {
      "description": "シーンのリスト。2〜4個推奨。",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "goal",
          "outcome"
        ],
        "properties": {
          "title": {
            "description": "シーンタイトル。3〜100文字推奨。",
            "type": "string"
          },
          "pov": {
            "description": "視点（誰の視点で描くか）",
            "type": "string"
          },
          "goal": {
            "description": "シーンの目標。",
            "type": "string"
          },
          "conflict": {
            "description": "シーンの葛藤。",
            "type": "string"
          },
          "outcome": {
            "description": "シーンの結果。",
            "type": "string",
            "minLength": 1
          },
          "characters": {
            "description": "登場キャラクター。1〜10個推奨。",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_events": {
            "description": "主要イベント。1〜5個推奨。",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "setting": {
            "description": "舞台設定。",
            "type": "string"
          }
        }
      }
    }
  }
}