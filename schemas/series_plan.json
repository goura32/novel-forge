{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlan",
  "type": "object",
  "required": ["title", "logline", "genre", "themes", "selling_points", "world", "main_characters", "planned_volumes"],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128,
      "description": "シリーズのタイトルすること検索力・宣伝力を考慮した、商業的に魅力的なタイトル。"
    },
    "logline": {
      "type": "string",
      "maxLength": 400,
      "description": "シリーズのあらすじ（1-2文）"
    },
    "genre": {
      "type": "array",
      "items": {"type": "string", "maxLength": 64},
      "minItems": 1,
      "maxItems": 3,
      "description": "ジャンル（1-3個）"
    },
    "target_audience": {
      "type": "string",
      "maxLength": 200,
      "description": "ターゲット読者（例: 10代後半〜20代の女性、ミステリー愛好者）"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64,
        "description": "テーマ"
      }
    },
    "selling_points": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 128,
        "description": "売りポイント。"
      }
    },
    "world": {
      "type": "object",
      "required": ["summary", "rules"],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 500,
          "description": "世界観の概要"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 200,
            "description": "世界観のルール"
          }
        }
      }
    },
    "main_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "arc"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 64,
            "description": "キャラクター名"
          },
          "role": {
            "type": "string",
            "enum": ["主人公", "ヒロイン", "相棒", "敵対者", "師匠", "仲間"],
            "description": "キャラクターの役割。上記6種から選択。"
          },
          "arc": {
            "type": "string",
            "maxLength": 200,
            "description": "キャラクターの成長・変化"
          }
        }
      }
    },
    "planned_volumes": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["title", "premise"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 128,
            "description": "巻タイトル"
          },
          "premise": {
            "type": "string",
            "maxLength": 200,
            "description": "巻のあらすじ"
          }
        }
      }
    }
  }
}
