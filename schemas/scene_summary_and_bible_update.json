{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummaryAndBibleUpdate",
  "type": "object",
  "properties": {
    "summary": { "type": "string", "maxLength": 1000, "description": "シーンの要約" },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subject", "predicate", "object"],
        "properties": {
          "subject": { "type": "string" },
          "predicate": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    },
    "continuity_notes": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "maxLength": 64},
          "role": {"type": "string", "maxLength": 64},
          "personality": {"type": "string", "maxLength": 200},
          "appearance": {"type": "string", "maxLength": 200},
          "motivation": {"type": "string", "maxLength": 200},
          "arc": {"type": "string", "maxLength": 200},
          "state": {"type": "string", "maxLength": 200},
          "is_new": {"type": "boolean"}
        }
      }
    },
    "foreshadowing": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string", "maxLength": 200 },
          "type": { "type": "string", "enum": ["setup", "resolution"] }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "character_a": { "type": "string", "maxLength": 64 },
          "character_b": { "type": "string", "maxLength": 64 },
          "type": { "type": "string", "maxLength": 64 },
          "change_direction": { "type": "string", "enum": ["improved", "worsened", "changed", "unchanged"] },
          "trigger_event": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "subplots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string", "maxLength": 128 },
          "status": { "type": "string", "enum": ["not_started", "in_progress", "completed"] },
          "progress_note": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": { "type": "string", "maxLength": 64 },
          "definition": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "world_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": { "type": "string", "maxLength": 200 }
        }
      }
    }
  }
}
