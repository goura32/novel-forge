{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummaryAndBibleUpdate",
  "type": "object",
  "properties": {
    "summary": {
      "description": "シーンの要約",
      "type": "string"
    },
    "facts": {
      "description": "事実記録",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate",
          "object"
        ],
        "properties": {
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        }
      }
    },
    "continuity_notes": {
      "description": "連続性メモ",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "characters": {
      "description": "キャラクター",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "personality": {
            "type": "string"
          },
          "appearance": {
            "type": "string"
          },
          "motivation": {
            "type": "string"
          },
          "arc": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "is_new": {
            "type": "boolean"
          }
        }
      }
    },
    "foreshadowing": {
      "description": "伏線リスト",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "設置",
              "回収"
            ]
          }
        }
      }
    },
    "relationships": {
      "description": "キャラクター関係",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "character_a": {
            "type": "string"
          },
          "character_b": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "change_direction": {
            "type": "string",
            "enum": [
              "改善",
              "悪化",
              "変化",
              "変化なし"
            ]
          },
          "trigger_event": {
            "type": "string"
          }
        }
      }
    },
    "subplots": {
      "description": "サブプロット",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "description": "一意識別子",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "未着手",
              "進行中",
              "完了"
            ]
          },
          "progress_note": {
            "type": "string"
          }
        }
      }
    },
    "glossary": {
      "description": "用語集",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          }
        }
      }
    },
    "world_rules": {
      "description": "世界観ルール",
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "rule": {
                "type": "string"
              }
            }
          },
          {
            "type": "string"
          }
        ]
      }
    }
  },
  "required": [
    "summary",
    "facts",
    "characters",
    "foreshadowing",
    "relationships",
    "subplots",
    "world_rules",
    "continuity_notes"
  ]
}