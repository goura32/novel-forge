{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSummaryAndBibleUpdate",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "description": "シーンの要約"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject",
          "predicate",
          "object"
        ],
        "properties": {
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        },
        "description": "新しく抽出した事実"
      },
      "description": "事実記録"
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "連続性メモ"
      },
      "description": "連続性メモ"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "personality": {
            "type": "string"
          },
          "appearance": {
            "type": "string"
          },
          "motivation": {
            "type": "string"
          },
          "arc": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "is_new": {
            "type": "boolean"
          }
        },
        "description": "更新されたキャラクター"
      },
      "description": "キャラクター"
    },
    "foreshadowing": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "設置",
              "回収"
            ]
          }
        },
        "description": "更新された伏線"
      },
      "description": "伏線リスト"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "character_a": {
            "type": "string"
          },
          "character_b": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "change_direction": {
            "type": "string",
            "enum": [
              "改善",
              "悪化",
              "変化",
              "変化なし"
            ]
          },
          "trigger_event": {
            "type": "string"
          }
        },
        "description": "更新された関係"
      },
      "description": "キャラクター関係"
    },
    "subplots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "一意識別子"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "未着手",
              "進行中",
              "完了"
            ]
          },
          "progress_note": {
            "type": "string"
          }
        },
        "description": "更新されたサブプロット"
      },
      "description": "サブプロット"
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          }
        },
        "description": "更新された用語"
      },
      "description": "用語集"
    },
    "world_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": {
            "type": "string"
          }
        },
        "description": "更新された世界観ルール"
      },
      "description": "世界観ルール"
    }
  },
  "required": [
    "summary",
    "facts",
    "characters",
    "foreshadowing",
    "relationships",
    "subplots",
    "world_rules",
    "continuity_notes"
  ]
}