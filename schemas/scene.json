{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scene",
  "type": "object",
  "required": [
    "title",
    "content"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 128
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16000
    }
  }
}