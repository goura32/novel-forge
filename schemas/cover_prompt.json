{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoverPrompt",
  "type": "object",
  "required": [
    "title",
    "visual_elements",
    "style"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "作品タイトル"
    },
    "visual_elements": {
      "type": "object",
      "required": [
        "subject"
      ],
      "properties": {
        "subject": {
          "type": "object",
          "description": "メインビジュアルの主体",
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string",
              "maxLength": 500,
              "description": "ビジュアルの詳細説明（英語の画像生成プロンプト用）"
            },
            "characters": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "appearance"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 64
                  },
                  "appearance": {
                    "type": "string",
                    "maxLength": 200
                  }
                }
              }
            }
          }
        },
        "background": {
          "type": "object",
          "properties": {
            "setting": {
              "type": "string",
              "maxLength": 300,
              "description": "背景の場面説明"
            },
            "atmosphere": {
              "type": "string",
              "maxLength": 200,
              "description": "雰囲気（暗い、明るい、幻想的等）"
            }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "significance"
            ],
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 64
              },
              "significance": {
                "type": "string",
                "maxLength": 200
              }
            }
          },
          "description": "物語を象徴するアイテム・モチーフ",
          "minItems": 1
        }
      }
    },
    "style": {
      "type": "object",
      "properties": {
        "genre": {
          "type": "string",
          "maxLength": 64,
          "description": "ジャンル"
        },
        "tone": {
          "type": "string",
          "maxLength": 64,
          "description": "トーン（ダーク、ライト、エピック等）"
        },
        "color_palette": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 32
          },
          "description": "カラーパレット（3〜5色）",
          "minItems": 3,
          "maxItems": 5
        },
        "composition": {
          "type": "string",
          "enum": [
            "portrait",
            "landscape",
            "action",
            "symbolic",
            "atmospheric"
          ],
          "description": "構図タイプ"
        }
      }
    },
    "negative_prompt": {
      "type": "string",
      "maxLength": 500,
      "description": "画像生成時に除外したい要素"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "series_name": {
          "type": "string",
          "maxLength": 128
        },
        "volume_number": {
          "type": "integer",
          "minimum": 1
        },
        "target_audience": {
          "type": "string",
          "maxLength": 50
        }
      }
    }
  }
}
