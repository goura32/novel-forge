{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeOutline",
  "type": "object",
  "required": ["volume_number", "title", "premise", "chapters", "scenes"],
  "properties": {
    "volume_number": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "maxLength": 128 },
    "premise": { "type": "string", "maxLength": 200 },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "title", "purpose"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "maxLength": 128 },
          "purpose": {
            "type": "string",
            "enum": ["introduction", "rising_action", "turning_point", "climax", "resolution"]
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "chapter_number", "title"],
        "properties": {
          "number": { "type": "integer", "minimum": 1, "description": "シーン番号。巻通しの連番（1,2,3,...）。章ごとに1から振り直さない。" },
          "chapter_number": { "type": "integer", "minimum": 1, "description": "属する章番号" },
          "title": { "type": "string", "maxLength": 128 },
          "pov": { "type": "string", "maxLength": 64 },
          "goal": { "type": "string", "description": "シーンの目標" },
          "conflict": { "type": "string", "maxLength": 200 },
          "outcome": { "type": "string", "maxLength": 200 },
          "characters": { "type": "array", "items": { "type": "string", "maxLength": 64 } }
        }
      }
    }
  }
}
