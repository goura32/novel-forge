{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VolumeOutline",
  "type": "object",
  "required": ["volume_number", "title", "premise", "chapters"],
  "properties": {
    "volume_number": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "maxLength": 128 },
    "premise": { "type": "string", "maxLength": 200 },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "purpose", "scenes"],
        "properties": {
          "title": { "type": "string", "maxLength": 128 },
          "purpose": {
            "type": "string",
            "enum": ["introduction", "rising_action", "turning_point", "climax", "resolution"]
          },
          "scenes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "maxLength": 128 },
                "pov": { "type": "string", "maxLength": 64 },
                "goal": { "type": "string", "description": "シーンの目標" },
                "conflict": { "type": "string", "maxLength": 200 },
                "outcome": { "type": "string", "maxLength": 200 },
                "characters": { "type": "array", "items": { "type": "string", "maxLength": 64 } }
              }
            }
          }
        }
      }
    }
  },
  "description": "LLMは chapters ごとに title, purpose, scenes を生成する。number と chapter_number は engine で機械採番されるため含めない。"
}
