{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCoreRevision",
  "description": "シリーズ企画（核）の改訂結果",
  "type": "object",
  "required": ["title", "logline", "genre", "target_audience", "themes", "selling_points", "world", "changes"],
  "properties": {
    "title": { "type": "string", "maxLength": 128, "description": "シリーズのタイトル" },
    "logline": { "type": "string", "maxLength": 200, "description": "シリーズのあらすじ" },
    "genre": { "type": "array", "items": { "type": "string", "maxLength": 64 } },
    "target_audience": { "type": "string", "maxLength": 128 },
    "themes": { "type": "array", "items": { "type": "string", "maxLength": 128 } },
    "selling_points": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
    "world": {
      "type": "object",
      "required": ["summary", "rules"],
      "properties": {
        "summary": { "type": "string", "maxLength": 500 },
        "rules": { "type": "array", "items": { "type": "string", "maxLength": 200 } }
      }
    },
    "changes": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "description": "修正内容のリスト。各要素は修正箇所と修正結果を簡潔に記述する"
    }
  }
}
