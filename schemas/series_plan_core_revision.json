{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCoreRevision",
  "description": "シリーズ企画（核）の改訂結果",
  "type": "object",
  "required": [
    "title",
    "logline",
    "genre",
    "target_audience",
    "themes",
    "selling_points",
    "world",
    "changes"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 500,
      "description": "シリーズのタイトル（500文字以内）"
    },
    "logline": {
      "type": "string",
      "maxLength": 500,
      "description": "シリーズのあらすじ（500文字以内）"
    },
    "genre": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "description": "ジャンル（各64文字以内）"
    },
    "target_audience": {
      "type": "string",
      "maxLength": 500,
      "description": "ターゲット読者（500文字以内）"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "description": "テーマ（各128文字以内）"
    },
    "selling_points": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "description": "売りポイント（各200文字以内）"
    },
    "world": {
      "type": "object",
      "required": [
        "summary",
        "rules"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 1000,
          "description": "世界観の概要（1000文字以内）"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "description": "世界観のルール（各200文字以内）"
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string",
            "maxLength": 500,
            "description": "修正前のテキスト"
          },
          "after": {
            "type": "string",
            "maxLength": 500,
            "description": "修正後のテキスト"
          }
        }
      },
      "description": "修正前後のペアリスト。各要素は before（修正前）と after（修正後）を含むオブジェクト。"
    }
  }
}