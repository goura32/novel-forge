{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCore",
  "description": "シリーズ企画の核。タイトル、あらすじ、ジャンル、ターゲット、テーマ、売りポイント、世界観。",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 500,
      "description": "シリーズのタイトル（500文字以内）"
    },
    "logline": {
      "type": "string",
      "maxLength": 800,
      "description": "シリーズのあらすじ（1-2文、800文字以内）"
    },
    "genre": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "minItems": 1,
      "maxItems": 10,
      "description": "ジャンル（1-5個、各64文字以内）"
    },
    "target_audience": {
      "type": "string",
      "maxLength": 500,
      "description": "ターゲット読者（500文字以内）"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "minItems": 1,
      "description": "テーマ（1個以上、各64文字以内）"
    },
    "selling_points": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      },
      "minItems": 1,
      "description": "売りポイント（1個以上、各128文字以内）"
    },
    "world": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 1000,
          "description": "世界観の概要（1000文字以内）"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "description": "世界観のルール（各200文字以内）"
        }
      }
    }
  },
  "required": [
    "title",
    "logline",
    "genre",
    "themes",
    "selling_points",
    "world",
    "target_audience"
  ]
}