{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SeriesPlanCore",
  "description": "シリーズ企画の核。タイトル、あらすじ、ジャンル、ターゲット、テーマ、売りポイント、世界観。",
  "type": "object",
  "properties": {
    "title": {
      "description": "シリーズのタイトル（最大100文字）",
      "type": "string"
    },
    "logline": {
      "description": "シリーズのあらすじ（1-2文、最大800文字）",
      "type": "string"
    },
    "genre": {
      "description": "ジャンル（数個、各最大64文字）",
      "type": "array",
      "items": {
        "type": "string",
        "description": "ジャンル一覧"
      }
    },
    "target_audience": {
      "description": "ターゲット読者（最大500文字）",
      "type": "string"
    },
    "themes": {
      "description": "テーマ（1個以上、各最大64文字）",
      "type": "array",
      "items": {
        "type": "string",
        "description": "テーマ一覧"
      }
    },
    "selling_points": {
      "description": "売りポイント（1個以上、各最大128文字）",
      "type": "array",
      "items": {
        "type": "string",
        "description": "売りポイント一覧"
      }
    },
    "world": {
      "description": "世界観。summary で舞台設定を、rules で独自ルールを記述する。",
      "type": "object",
      "properties": {
        "summary": {
          "description": "世界観の概要",
          "type": "string"
        },
        "rules": {
          "description": "世界観の独自ルール",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "title",
    "slug",
    "logline",
    "genre",
    "themes",
    "selling_points",
    "world",
    "target_audience"
  ]
}